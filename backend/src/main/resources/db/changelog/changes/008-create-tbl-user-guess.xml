<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="008" author="composerguesser">
        <createTable tableName="tbl_user_guess">
            <column name="guess_id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_user_guess_user" references="tbl_user(user_id)"/>
            </column>
            <column name="excerpt_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_user_guess_excerpt" references="tbl_excerpt(excerpt_id)"/>
            </column>
            <column name="composer_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_user_guess_composer" references="tbl_composer(composer_id)"/>
            </column>
            <column name="guess_number" type="INT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
